# Copier en .env avant `docker compose up`.

# --- MongoDB ---
MONGO_USER=kbo
MONGO_PASSWORD=kbo_secret

# --- Tor (port de contrôle pour NEWNYM) ---
TOR_CONTROL_PASSWORD=tor_control_secret
# Nombre d'instances Tor dans le pool (plus = plus d'IP simultanées)
TOR_POOL_SIZE=6

# --- Airflow (interface web http://localhost:8080) ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
